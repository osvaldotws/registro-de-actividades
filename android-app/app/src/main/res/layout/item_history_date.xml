<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Date Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@color/emerald_50">

            <TextView
                android:id="@+id/tvHistoryDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/emerald_800"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="lunes, 7 de abril 2026"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewDay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/view_day"
                style="@style/Widget.Material3.Button.TextButton"
                android:textColor="@color/emerald_600"/>

        </LinearLayout>

        <!-- Activities Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/emerald_100"/>

        <!-- Activities List -->
        <LinearLayout
            android:id="@+id/activitiesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
